# Copy to .env.local (or set these in your MCP client's server env config)
PENPOT_BASE_URL=https://design.penpot.app
PENPOT_ACCESS_TOKEN=
PENPOT_TOKENS_PATH=./design-tokens/tokens.json

# Optional: only required for penpot_export_shape. Must belong to the same
# account as PENPOT_ACCESS_TOKEN above (see README's "Render/export capability").
# Leave unset to skip rendering support entirely.
PENPOT_LOGIN_EMAIL=
PENPOT_LOGIN_PASSWORD=
