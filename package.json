{
  "name": "@ai-dala/penpot-headless",
  "version": "0.1.0",
  "description": "Portable MCP server for headless Penpot project/file/content management via Penpot's RPC API. No browser, no Penpot plugin session required. Copy this directory to any project to reuse.",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "bin": {
    "penpot-headless": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "penpot",
    "mcp",
    "headless"
  ],
  "author": "Volodymyr Tytenko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tvolodi/penpot-mcp.git"
  },
  "homepage": "https://github.com/tvolodi/penpot-mcp#readme",
  "bugs": {
    "url": "https://github.com/tvolodi/penpot-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "@types/node": "^22.10.0"
  }
}
